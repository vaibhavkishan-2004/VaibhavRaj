{
  "testTimeout": 5000,
  "rootDir": "..",
  "modulePaths": ["."],
  "testEnvironment": "node",
  "testMatch": ["<rootDir>/test/**/*.spec.ts"],
  "collectCoverage": true,
  "coverageDirectory": "coverage",
  "collectCoverageFrom": ["./src/**/*"],
  "coveragePathIgnorePatterns": [".module.ts", ".modules.ts", "<rootDir>/src/main.ts"],
  "coverageThreshold": {
    "global": {
      "branches": 85,
      "functions": 85,
      "lines": 85,
      "statements": 85
    }
  },
  "moduleFileExtensions": ["js", "ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
